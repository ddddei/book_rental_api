# Server-only Apps Script Web App URL. Do not prefix this with NEXT_PUBLIC_.
APPS_SCRIPT_WEB_APP_URL=

# Optional soft-launch access gate. Set both values to require an operator PIN.
OPERATOR_ACCESS_CODE=
OPERATOR_ACCESS_COOKIE_SECRET=

# Planned for ROADMAP PHASE B. Leave blank until Supabase migration starts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
